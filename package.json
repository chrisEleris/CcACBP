{
  "name": "ccacbp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "node esbuild.config.mjs",
    "start": "node dist/server/index.js",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1000.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1000.0",
    "@aws-sdk/client-cost-explorer": "^3.1000.0",
    "@aws-sdk/client-ec2": "^3.1000.0",
    "@aws-sdk/client-ecs": "^3.1000.0",
    "@aws-sdk/client-iam": "^3.1000.0",
    "@aws-sdk/client-lambda": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.4.1",
    "@tanstack/react-router": "^1.163.3",
    "hono": "^4.6.0",
    "lucide-react": "^0.575.0",
    "recharts": "^3.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.27.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}