# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=file:./local.db

# AWS
AWS_REGION=us-east-1

# Authentication
# REQUIRED in production (NODE_ENV=production): the server will refuse to start without this.
# Optional in development/test. Use a strong random value (e.g. openssl rand -hex 32).
API_KEY=your-api-key-here

# Credential encryption key
# REQUIRED in production (NODE_ENV=production): used to encrypt data source credentials at rest
# using AES-256-GCM. The server will refuse to start without this in production.
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
